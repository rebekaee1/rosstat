forecasteconomy.com {
	# Embed SVG API: CORS for cross-origin <img> usage
	@embedapi path_regexp embedapi ^/api/v1/embed/
	header @embedapi Access-Control-Allow-Origin "*"

	# Embed widget routes: frameable from any domain (handle is mutually exclusive)
	@embed path_regexp embed ^/embed/(chart|card|table|ticker|compare)(/.*)?$
	handle @embed {
		header {
			Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
			X-Content-Type-Options "nosniff"
			Referrer-Policy "strict-origin-when-cross-origin"
			Content-Security-Policy "frame-ancestors *; default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'"
		}
		reverse_proxy localhost:3000
	}

	# All other routes: standard security headers
	handle {
		header {
			Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
			X-Content-Type-Options "nosniff"
			X-Frame-Options "SAMEORIGIN"
			Referrer-Policy "strict-origin-when-cross-origin"
			Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://mc.yandex.ru; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://mc.yandex.ru; connect-src 'self' https://mc.yandex.ru wss://mc.yandex.ru https://*.ingest.sentry.io;"
		}
		reverse_proxy localhost:3000
	}
}

www.forecasteconomy.com {
	redir https://forecasteconomy.com{uri} permanent
}
