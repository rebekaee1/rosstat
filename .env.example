# ============================================
# Forecast Economy — Environment Variables
# ============================================
# Copy to .env and change ALL passwords/secrets.
# If .env was ever committed to git, rotate ALL secrets immediately.
# ============================================

# Database password (CHANGE THIS in production!)
POSTGRES_PASSWORD=rustats_dev

# Redis password (CHANGE THIS in production!)
REDIS_PASSWORD=changeme

# Scheduler (Moscow time)
RUSTATS_SCHEDULER_CRON_HOUR=6
RUSTATS_SCHEDULER_CRON_MINUTE=0

# OLS forecast horizon
RUSTATS_FORECAST_STEPS=12

# Metrics endpoint protection token
RUSTATS_METRICS_TOKEN=

# Uvicorn workers (default: 2)
UVICORN_WORKERS=2
