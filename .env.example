# ============================================
# RuStats — Environment Variables
# ============================================
# Copy to .env and edit POSTGRES_PASSWORD.
# All other values are defaults for Docker deployment.
# ============================================

# Database password (CHANGE THIS in production!)
POSTGRES_PASSWORD=rustats_dev

# Scheduler (Moscow time)
RUSTATS_SCHEDULER_CRON_HOUR=6
RUSTATS_SCHEDULER_CRON_MINUTE=0

# OLS forecast horizon
RUSTATS_FORECAST_STEPS=12
